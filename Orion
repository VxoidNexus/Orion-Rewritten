                    while humanoid and humanoid.Health <= 27 do
                        wait(1)
                        humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                    end

                    pressSpace()
                    wait(0.5)
                    ensurePlayerInVehicle()
                    wait(0.5)
                    
                    showNotification("Stay at hospital location.")
                end)
            end)
        else
            showNotification("You are not dead.")
        end
    end
})

