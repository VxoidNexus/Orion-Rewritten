local function initializeSelfESP()
    for _, bone in ipairs(selfESPSkeleton) do
        if bone.line then
            bone.line:Remove()
        end
    end
    selfESPSkeleton = {}
    
    local bones = {
        {"Head", "UpperTorso"},
        {"UpperTorso", "LowerTorso"},
        {"UpperTorso", "LeftUpperArm"},
        {"LeftUpperArm", "LeftLowerArm"},
        {"LeftLowerArm", "LeftHand"},
        {"UpperTorso", "RightUpperArm"},
        {"RightUpperArm", "RightLowerArm"},
        {"RightLowerArm", "RightHand"},
        {"LowerTorso", "LeftUpperLeg"},
        {"LeftUpperLeg", "LeftLowerLeg"},
        {"LeftLowerLeg", "LeftFoot"},
        {"LowerTorso", "RightUpperLeg"},
        {"RightUpperLeg", "RightLowerLeg"},
        {"RightLowerLeg", "RightFoot"},
    }

    for _, bone in ipairs(bones) do
        local line = Drawing.new("Line")
        line.Thickness = 1
        line.Transparency = 1
        line.Color = getColorFromName(ESP.SelfEspColor)
        line.Visible = false
        table.insert(selfESPSkeleton, {line = line, from = bone[1], to = bone[2]})
    end
    
    if selfESPTracer then
        selfESPTracer:Remove()
    end
    selfESPTracer = Drawing.new("Line")
    selfESPTracer.Thickness = 1
    selfESPTracer.Transparency = 0.7
    selfESPTracer.Visible = false
    selfESPTracer.Color = getColorFromName(ESP.SelfEspColor)
end

local function updateSelfESP()
    if not ESP.SelfEsp or not LocalPlayer.Character then
        if selfESPTracer then selfESPTracer.Visible = false end
        for _, bone in ipairs(selfESPSkeleton) do
            if bone.line then bone.line.Visible = false end
        end
        return
    end
    
    local character = LocalPlayer.Character
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not rootPart then return end
    
    for _, bone in ipairs(selfESPSkeleton) do
        local part1 = character:FindFirstChild(bone.from)
        local part2 = character:FindFirstChild(bone.to)
        if part1 and part2 then
            local pos1, vis1 = Camera:WorldToViewportPoint(part1.Position)
            local pos2, vis2 = Camera:WorldToViewportPoint(part2.Position)
            if vis1 and vis2 then
                bone.line.From = Vector2.new(pos1.X, pos1.Y)
                bone.line.To = Vector2.new(pos2.X, pos2.Y)
                bone.line.Visible = true
            else
                bone.line.Visible = false
            end
        else
            bone.line.Visible = false
        end
    end
    
    if selfESPTracer then
        local rootPos, rootVis = Camera:WorldToViewportPoint(rootPart.Position)
        
        if rootVis then
            selfESPTracer.To = Vector2.new(rootPos.X, rootPos.Y)
            selfESPTracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            selfESPTracer.Visible = true
        else
            selfESPTracer.Visible = false
        end
    end
end

local function updateSelfESPColors()
    for _, bone in ipairs(selfESPSkeleton) do
        if bone.line then
            bone.line.Color = getColorFromName(ESP.SelfEspColor)
        end
    end
    
    if selfESPTracer then
        selfESPTracer.Color = getColorFromName(ESP.SelfEspColor)
    end
end

local function createTracer(player)
    if not player.Character then return end

    local tracer = Drawing.new("Line")
    tracer.Thickness = 1
    tracer.Transparency = 0.7
    tracer.Visible = false
    tracer.Color = getColorFromName(ESP.EspColor)

    tracerDrawings[player] = tracer
end

local function removeTracer(player)
    if tracerDrawings[player] then
        if tracerDrawings[player] then 
            tracerDrawings[player]:Remove() 
        end
        tracerDrawings[player] = nil
    end
end

local function updateTracers()
    for _, player in ipairs(Players:GetPlayers()) do
        if ESP.ShowTracer then
            if not tracerDrawings[player] then
                createTracer(player)
            end

            local tracer = tracerDrawings[player]
            if tracer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local rootPart = player.Character.HumanoidRootPart
                local rootPos, rootVis = Camera:WorldToViewportPoint(rootPart.Position)

                local dist = (Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and (rootPart.Position - Players.LocalPlayer.Character.HumanoidRootPart.Position).Magnitude) or 0

                if rootVis and dist <= ESP.MaxESPDistance then
                    if player == LocalPlayer then
                        if ESP.SelfEsp then
                            tracer.Color = getColorFromName(ESP.SelfEspColor)
                        else
                            tracer.Visible = false
                            return
                        end
                    else
                        tracer.Color = getColorFromName(ESP.EspColor)
                    end

                    tracer.To = Vector2.new(rootPos.X, rootPos.Y)
                    tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    tracer.Visible = true
                else
                    tracer.Visible = false
                end
            else
                if tracer then
                    tracer.Visible = false
                end
            end
        else
            if tracerDrawings[player] then
                tracerDrawings[player].Visible = false
            end
        end
    end
end

