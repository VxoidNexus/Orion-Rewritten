local function findWeaponRemote()
    local possiblePaths = {
        ReplicatedStorage,
        ReplicatedStorage:FindFirstChild("Events"),
        ReplicatedStorage:FindFirstChild("Remotes"),
        ReplicatedStorage:FindFirstChild("WeaponSystem"),
        ReplicatedStorage:FindFirstChild("CombatSystem"),
        ReplicatedStorage:FindFirstChild("ShootingSystem"),
        ReplicatedStorage:FindFirstChild("WeaponRemotes"),
        ReplicatedStorage:FindFirstChild("WeaponRemote")
    }
    
    local remoteNames = {
        "FireWeapon",
        "Shoot",
        "Fire",
        "FireGun",
        "WeaponFire",
        "ShootWeapon",
        "FireRemote",
        "ShootRemote"
    }
    
    for _, path in ipairs(possiblePaths) do
        if path then
            for _, remoteName in ipairs(remoteNames) do
                local remote = path:FindFirstChild(remoteName)
                if remote and (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) then
                    return remote
                end
            end
        end
    end
    
    for _, remote in pairs(ReplicatedStorage:GetDescendants()) do
        if remote:IsA("RemoteEvent") then
            local nameLower = remote.Name:lower()
            if nameLower:find("fire") or nameLower:find("shoot") or nameLower:find("weapon") then
                return remote
            end
        end
    end
    
    return nil
end

