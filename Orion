local function GetClosestPlayer()
    local closest, shortest = nil, Settings.Aimbot.FOV
    local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                if Settings.Aimbot.TeamCheck and player.Team == LocalPlayer.Team then
                    continue
                end
                
                local head = player.Character.Head
                local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
                
                if onScreen then
                    local distance = (screenCenter - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                    if distance < shortest then
                        closest = player
                        shortest = distance
                    end
                end
            end
        end
    end
    
    return closest
end

local isShooting = false

local function isPlayerInCrosshair()
    if not LocalPlayer.Character then return false end
    
    local viewportSize = Camera.ViewportSize
    local screenCenter = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    local ray = Camera:ViewportPointToRay(screenCenter.X, screenCenter.Y)
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
    
    local raycastResult = workspace:Raycast(ray.Origin, ray.Direction * 2000, raycastParams)
    
    if raycastResult and raycastResult.Instance then
        local hitPart = raycastResult.Instance
        local character = hitPart.Parent
        
        if character and character:FindFirstChild("Humanoid") then
            local player = Players:GetPlayerFromCharacter(character)
            if player and player ~= LocalPlayer then
                if Settings.Aimbot.TriggerBot.TeamCheck and player.Team == LocalPlayer.Team then
                    return false
                end
                
                local humanoid = character:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    return true
                end
            end
        end
    end
    
    return false
end

RunService.RenderStepped:Connect(function()
    UpdateAimbotFOVCircle()
    UpdateTriggerBotFOVCircle()
    
    if Settings.Aimbot.Enabled and Settings.Aimbot.Active then
        if not Settings.Aimbot.Target or not Settings.Aimbot.Target.Character or 
           not Settings.Aimbot.Target.Character:FindFirstChild("Head") or
           not Settings.Aimbot.Target.Character:FindFirstChild("Humanoid") or
           Settings.Aimbot.Target.Character.Humanoid.Health <= 0 then
            Settings.Aimbot.Target = GetClosestPlayer()
        end
        
        if Settings.Aimbot.Target and Settings.Aimbot.Target.Character and 
           Settings.Aimbot.Target.Character:FindFirstChild("Head") then
            local head = Settings.Aimbot.Target.Character.Head
            local targetPosition = head.Position
            
            local hrp = Settings.Aimbot.Target.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local velocity = hrp.AssemblyLinearVelocity
                targetPosition = targetPosition + (velocity * Settings.Aimbot.Prediction)
            end
            
            local targetCF = CFrame.new(Camera.CFrame.Position, targetPosition)
            local smoothness = Settings.Aimbot.Strength / 100
            Camera.CFrame = Camera.CFrame:Lerp(targetCF, smoothness)
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not Settings.Aimbot.TriggerBot.Enabled or not Settings.Aimbot.TriggerBot.Active then 
        if isShooting then
            pcall(function()
                if mouse1release then
                    mouse1release()
                else
                    local VirtualInputManager = game:GetService("VirtualInputManager")
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                end
                isShooting = false
            end)
        end
        return 
    end
    
    local inCrosshair = isPlayerInCrosshair()
    
    if inCrosshair and not isShooting then
        pcall(function()
            if mouse1press then
                mouse1press()
                isShooting = true
            elseif mouse1click then
                mouse1click()
            else
                local VirtualInputManager = game:GetService("VirtualInputManager")
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                isShooting = true
            end
        end)
    elseif not inCrosshair and isShooting then
        pcall(function()
            if mouse1release then
                mouse1release()
            else
                local VirtualInputManager = game:GetService("VirtualInputManager")
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
            end
            isShooting = false
        end)
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    local inputKey = nil
    
    if input.KeyCode and input.KeyCode ~= Enum.KeyCode.Unknown then
        inputKey = input.KeyCode.Name
    end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        inputKey = "MouseButton1"
    elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
        inputKey = "MouseButton2"
    elseif input.UserInputType == Enum.UserInputType.MouseButton3 then
        inputKey = "MouseButton3"
    end
    
    if inputKey and inputKey == Settings.Aimbot.Keybind and Settings.Aimbot.Enabled then
        Settings.Aimbot.Active = not Settings.Aimbot.Active
        
        if Settings.Aimbot.Active then
            local target = GetClosestPlayer()
            if target then
                Settings.Aimbot.Target = target
            else
                Settings.Aimbot.Active = false
            end
        else
            Settings.Aimbot.Target = nil
        end
    end
    
    if inputKey and inputKey == Settings.Aimbot.TriggerBot.Keybind and Settings.Aimbot.TriggerBot.Enabled then
        Settings.Aimbot.TriggerBot.Active = not Settings.Aimbot.TriggerBot.Active
    end
end)

