local function LoadAllConfigsFromFiles()
    Configs = {}
    local success, files = pcall(function()
        return listfiles(ConfigFolder)
    end)
    
    if not success then return end
    
    for _, filePath in pairs(files) do
        local fileName = filePath:match("^.+/(.+)$") or filePath
        if fileName:match("%.json$") then
            local configName = fileName:gsub("%.json$", "")
            local success2, data = pcall(function()
                return HttpService:JSONDecode(readfile(filePath))
            end)
            
            if success2 and data then
                Configs[configName] = data
            end
        end
    end
end

local function SaveConfigToFile(configName, configData)
    local filePath = ConfigFolder .. "/" .. configName .. ".json"
    local success, err = pcall(function()
        local jsonData = HttpService:JSONEncode(configData)
        writefile(filePath, jsonData)
    end)
    return success
end

local function DeleteConfigFile(configName)
    local filePath = ConfigFolder .. "/" .. configName .. ".json"
    if isfile(filePath) then
        delfile(filePath)
        return true
    end
    return false
end

