            if targetRoot then
                local distance = (rootPart.Position - targetRoot.Position).Magnitude
                if distance <= MAX_DISTANCE then
                    wantedPlayerInRange = true
                    break
                end
            end
        end
    end

    if wantedPlayerInRange then
        startPressingE()
    else
        stopPressingE()
    end
end

