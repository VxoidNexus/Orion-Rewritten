            if tool:IsA("Tool") then
                updateCrosshair(tool)
            end
        end

        connections.toolAdded = plr.Character.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                updateCrosshair(child)
            end
        end)
    end
end

